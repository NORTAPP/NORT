# ─── Privy Auth ──────────────────────────────────────────────────────────────
PRIVY_APP_ID=
PRIVY_APP_SECRET=
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_USE_MOCK_AUTH=false

# ─── Pretium (On-ramp / Off-ramp) ───────────────────────────────────────────
# Get these from Pretium after onboarding: https://docs.pretium.africa/
PRETIUM_API_KEY=              # Consumer key — used as x-api-key header for all API calls
PRETIUM_SECRET_KEY=           # Secret key — store securely, may be used for future webhook signing
PRETIUM_CHECKOUT_KEY=         # Checkout key — for hosted checkout flows (reserved)
PRETIUM_BASE_URL=             # Base URL from Pretium (e.g. https://api.pretium.africa)

# Your backend's public URL — Pretium sends webhooks to {this}/api/pretium/webhook
PRETIUM_WEBHOOK_BASE_URL=     # e.g. https://your-app.onrender.com

# Defaults (override if needed)
PRETIUM_CHAIN=BASE            # Blockchain: BASE, CELO, STELLAR, TRON, SCROLL, SOLANA, POLYGON, ETHEREUM, BINANCE SMART CHAIN
PRETIUM_ASSET=USDC            # Crypto asset: USDC, USDT, CUSD
PRETIUM_FIAT_CURRENCY=KES     # Fiat currency code
PRETIUM_MOBILE_NETWORK=Safaricom  # Mobile network: Safaricom, Airtel, MTN, etc.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=                 # PostgreSQL connection string (Neon, Supabase, etc.)

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=          # Backend URL for dashboard (e.g. http://localhost:8000)
